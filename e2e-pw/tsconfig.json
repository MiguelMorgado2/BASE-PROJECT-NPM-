{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@support/*": ["src/support/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@env/*": ["src/env/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "test-results", "playwright-report"]
}
